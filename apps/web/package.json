{
  "name": "@legacyvault/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && next build",
    "start": "next start -p 3000",
    "postinstall": "prisma generate --schema=../../packages/database/prisma/schema.prisma || true",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@legacyvault/database": "*",
    "@legacyvault/shared": "*",
    "@prisma/client": "^5.14.0",
    "@tanstack/react-query": "^5.40.0",
    "clsx": "^2.1.1",
    "jose": "^5.6.3",
    "lucide-react": "^0.383.0",
    "next": "^15.0.0",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.4",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.0",
    "@hookform/resolvers": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
