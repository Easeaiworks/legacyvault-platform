# === Application ===
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# === Database ===
DATABASE_URL=postgresql://legacyvault:legacyvault@localhost:5432/legacyvault?schema=public
# For production, use IAM auth or AWS Secrets Manager — never commit real URLs

# === Redis (sessions, rate limiting, queue) ===
REDIS_URL=redis://localhost:6379

# === Object storage (local: Minio; prod: S3) ===
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=legacyvault-documents-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_FORCE_PATH_STYLE=true

# === KMS (field-level encryption key) ===
# Local dev: a base64-encoded 32-byte key. Prod: use AWS KMS ARN.
# Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=CHANGE_ME_base64_32_byte_key_for_local_dev_only_do_not_use_in_prod
KMS_KEY_ID=arn:aws:kms:us-east-1:000000000000:key/PLACEHOLDER

# === Authentication ===
# Options: workos | clerk | local (for dev only)
AUTH_PROVIDER=local
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT — only used for local/dev fallback auth
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_local_dev_only
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# === Stripe (payments + identity verification) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# === Email (Postmark) ===
POSTMARK_API_KEY=
EMAIL_FROM=noreply@legacyvault.app

# === Observability ===
SENTRY_DSN=
DATADOG_API_KEY=
LOG_LEVEL=info

# === Security ===
# CORS allowed origins, comma-separated
CORS_ORIGINS=http://localhost:3000
# Rate limit: requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# === Feature flags ===
FEATURE_REGISTRY_ENABLED=false
FEATURE_HEIRTRACE_ENABLED=false
